#!/usr/bin/env bash
# push 対象の差分に /simplify をかけ、変更が出たら push を止めるゲート。
set -uo pipefail

[ "${PR_SIMPLIFY_RUNNING:-}" = "1" ] && exit 0       # 再入防止
command -v claude >/dev/null 2>&1 || exit 0          # claude が無ければスキップ

cd "$(git rev-parse --show-toplevel)" || exit 0

prompt='/simplify この push で送る差分（git diff @{upstream}..HEAD 相当、無ければ origin/main...HEAD）だけを対象にして。修正はコミットまでで止めて、push はしないで。'
PR_SIMPLIFY_RUNNING=1 claude -p "$prompt" >&2 || exit 0

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "[pre-push] simplify が変更を加えました。確認・コミットして再 push してください。" >&2
  exit 1
fi
