# ローカル dev（pnpm start）は vite cloudflare adapter の miniflare D1（binding: DB）を使うため
# DATABASE_URL は設定しない。dev DB へのマイグレーション適用は `pnpm run d1:apply:local` を使う。
# DATABASE_URL(file:) は E2E（start:e2e で test.db を明示）やテストでのみ利用するフォールバック。
# wrangler.toml の D1 設定に利用される Database ID (deploy 時に必要)
D1_DATABASE_ID=

# Discord webhook URL for alert
DISCORD_WEBHOOK_URL=

# Supabase設定
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=

# ログレベル(debug,info,warn,error,silent)。未記載の場合の初期値はinfo
LOG_LEVEL=
