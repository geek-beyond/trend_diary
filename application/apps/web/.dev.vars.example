# wrangler.toml の D1 設定に利用される Database ID (deploy 時に必要)
D1_DATABASE_ID=

# Discord webhook URL for alert
DISCORD_WEBHOOK_URL=

# Supabase設定
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=

# Cloudflare Turnstileのサイトキー(公開値)。未設定の場合はウィジェットを描画しない。
# ローカル/E2Eで動作確認する場合はCloudflareのテスト用sitekey(`1x00000000000000000000AA`)を使うと常にpassする。
TURNSTILE_SITE_KEY=

# Cloudflare Turnstileのシークレットキー(秘匿)。未設定の場合はサーバー側のCAPTCHA検証をスキップする。
# ローカルで検証まで動作確認する場合はテスト用secret(`1x0000000000000000000000000000000AA`)を使うと常にpassする。
TURNSTILE_SECRET_KEY=

# ログレベル(debug,info,warn,error,silent)。未記載の場合の初期値はinfo
LOG_LEVEL=
