{
  "$schema": "https://biomejs.dev/schemas/2.0.6/schema.json",
  "root": true,
  "extends": ["./packages/lint/biome.base.json"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/.vscode/",
      "!src/web/client/components/shadcn",
      "!src/web/client/components/customized",
      "!**/supabase",
      "!migrations/meta"
    ]
  },
  "plugins": ["./packages/lint/no-use-direct-dom-a-element.grit"]
}
