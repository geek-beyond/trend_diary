{
  "name": "my-app",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @trend-diary/web dev",
    "build": "pnpm --filter @trend-diary/web build",
    "lint": "oxlint && oxfmt --check && import-lint && pnpm -r typecheck",
    "import-lint": "import-lint",
    "knip": "knip",
    "similarity": "similarity-ts apps packages --no-types --threshold 0.9 --exclude '**/components/shadcn/**' --exclude '**/components/customized/**' --exclude '**/migrations/**' --fail-on-duplicates",
    "check": "oxlint && oxfmt --check",
    "check:fix": "oxlint --fix && oxfmt",
    "supabase:start": "supabase start -x realtime,storage-api,imgproxy,mailpit,postgrest,postgres-meta,studio,edge-runtime,logflare,vector,supavisor",
    "supabase:status": "supabase status",
    "supabase:stop": "supabase stop"
  },
  "devDependencies": {
    "@import-lint/cli": "0.1.6",
    "knip": "^6.27.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "packageManager": "pnpm@11.5.1"
}
