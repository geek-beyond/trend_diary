{
  "name": "my-app",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  },
  "scripts": {
    "dev": "pnpm --filter @trend-diary/web dev",
    "build": "pnpm --filter @trend-diary/web build",
    "typecheck": "tsgo --noEmit",
    "lint": "biome ci . && pnpm -r typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write . --unsafe",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "supabase:start": "supabase start -x realtime,storage-api,imgproxy,mailpit,postgrest,postgres-meta,studio,edge-runtime,logflare,vector,supavisor",
    "supabase:status": "supabase status",
    "supabase:stop": "supabase stop"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@cloudflare/workers-types": "^4.20260507.1",
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20251209.1",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "0.31.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "vitest-mock-extended": "^4.0.0",
    "wrangler": "^4.95.0"
  }
}
