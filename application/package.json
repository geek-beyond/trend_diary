{
  "name": "my-app",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  },
  "scripts": {
    "start": "react-router dev",
    "build": "react-router build",
    "test:client": "vitest run -c src/test/vitest/client/config.ts",
    "test:domain": "vitest run -c src/test/vitest/domain/config.ts",
    "test:server": "vitest run -c src/test/vitest/server/config.ts",
    "test:common": "vitest run -c src/test/vitest/common/config.ts",
    "test:cron": "vitest run -c src/test/vitest/cron/config.ts",
    "e2e": "playwright test --config=src/test/e2e/playwright.config.ts",
    "e2e:report": "playwright show-report src/test/e2e/playwright-report",
    "e2e:gen": "playwright codegen --config=src/test/e2e/playwright.config.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "biome ci . && pnpm run typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write . --unsafe",
    "d1:apply:local": "wrangler d1 migrations apply trend-diary-db --local",
    "d1:apply:remote": "wrangler d1 migrations apply trend-diary-db --remote",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "supabase:start": "supabase start -x realtime,storage-api,imgproxy,mailpit,postgrest,postgres-meta,studio,edge-runtime,logflare,vector,supavisor",
    "supabase:status": "supabase status",
    "supabase:stop": "supabase stop",
    "storybook": "storybook dev -p 6006",
    "test-storybook": "vitest run -c src/test/vitest/storybook/config.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.76.1",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "hono": "^4.12.23",
    "hono-react-router-adapter": "^0.6.5",
    "lucide-react": "^1.17.0",
    "neverthrow": "^8.2.0",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.16.0",
    "recharts": "^3.8.1",
    "rss-parser": "^3.13.0",
    "sonner": "^2.0.3",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "vaul": "^1.1.2",
    "vite-plugin-babel": "^1.7.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@chromatic-com/storybook": "^5.2.1",
    "@cloudflare/vitest-pool-workers": "^0.16.12",
    "@cloudflare/workers-types": "^4.20260507.1",
    "@faker-js/faker": "^10.4.0",
    "@hono/vite-dev-server": "^0.26.0",
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "^7.16.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20251209.1",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "0.31.10",
    "jsdom": "^26.1.0",
    "playwright": "^1.60.0",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-mock-extended": "^4.0.0",
    "wrangler": "^4.95.0"
  }
}
