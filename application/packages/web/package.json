{
  "name": "@trend-diary/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "start": "react-router dev",
    "build": "react-router build",
    "test": "pnpm run test:client && pnpm run test:server",
    "test:client": "vitest run -c src/test/vitest/client/config.ts",
    "test:server": "vitest run -c src/test/vitest/server/config.ts",
    "test-storybook": "vitest run -c src/test/vitest/storybook/config.ts",
    "e2e": "playwright test --config=src/test/e2e/playwright.config.ts",
    "e2e:report": "playwright show-report src/test/e2e/playwright-report",
    "e2e:gen": "playwright codegen --config=src/test/e2e/playwright.config.ts",
    "storybook": "storybook dev -p 6006",
    "typecheck": "tsgo --noEmit",
    "d1:apply:local": "wrangler d1 migrations apply trend-diary-db --local",
    "d1:apply:remote": "wrangler d1 migrations apply trend-diary-db --remote"
  },
  "dependencies": {
    "@trend-diary/common": "workspace:*",
    "@trend-diary/datastore": "workspace:*",
    "@trend-diary/domain": "workspace:*",
    "@trend-diary/notification": "workspace:*",
    "@hono/zod-validator": "^0.7.6",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.76.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "hono-react-router-adapter": "^0.6.5",
    "lucide-react": "^1.17.0",
    "neverthrow": "catalog:",
    "next-themes": "^0.4.6",
    "pino": "catalog:",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.16.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.3",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "vaul": "^1.1.2",
    "zod": "catalog:"
  }
}
