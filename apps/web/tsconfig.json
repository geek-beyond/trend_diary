{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["@cloudflare/workers-types", "vite/client", "vitest/globals", "@react-router/node"],
    "rootDirs": [".", "./.react-router/types"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [".react-router/types/**/*", "src"],
  "exclude": ["supabase"]
}
